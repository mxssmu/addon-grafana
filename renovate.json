{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "packageRules": [
    {
      "matchPaths": ["grafana/Dockerfile"],
      "matchPackageNames": ["grafana"],
      "automerge": false,
      "labels": ["dependencies"]
    }
  ],
  "dockerfile": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["grafana/Dockerfile"],
      "matchStrings": [
        "GRAFANA_VERSION=\"v(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "grafana/grafana",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    }
  ]
}
